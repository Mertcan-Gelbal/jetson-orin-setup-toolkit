# ============================================================
# Jetson Orin Post-Install Configuration
# ============================================================
# Edit this file (or export these variables in your shell) to
# customize the installation. The defaults are sane for a fresh
# Jetson Orin running JetPack 6.x on Ubuntu 22.04.
# ============================================================

# ---- Target detection ----
# auto | jp6 | jp5 | ubuntu2204
TARGET_PROFILE="auto"

# auto, or an explicit JetPack string for documentation/logging only
TARGET_JETPACK="auto"

# ---- Python packages ----
# apt -> use distribution packages where available
# pip -> additionally install the listed packages via pip
PYTHON_PACKAGE_MODE="apt"

# ---- OpenCV ----
# apt -> RECOMMENDED on Jetson (build ships with GStreamer + CUDA support)
# pip -> NOT recommended for camera/GStreamer workflows on Jetson
OPENCV_SOURCE="apt"

# ---- Optional components ----
INSTALL_DOCKER="yes"
INSTALL_JETSON_STATS="yes"
INSTALL_PYTORCH="yes"
RUN_JETSONHACKS_SETUP="yes"

# ---- jetson-stats version ----
# "latest" or a pinned version like "4.2.9"
JETSON_STATS_VERSION="latest"

# ---- Behavior ----
# Ask the user for confirmation before starting the install.
# Set to "no" for unattended / fleet provisioning.
ASK_CONFIRM="yes"

# ---- Logging ----
# Leave empty to auto-generate "setup_verify_YYYYMMDD_HHMMSS.log"
LOG_FILE=""
